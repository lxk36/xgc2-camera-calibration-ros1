    {
      "id": "xgc2-camera-intrinsic-calibrator-ros1",
      "version": "2.0.0",
      "label": "XGC2 camera intrinsic calibration WebUI",
      "description": "Serve a local WebUI with a 3D sample guide and X/Y/Size/Skew coverage: auto-collect diverse chessboard views, solve intrinsics (cv2-direct), and persist camera_matrix + distortion.",
      "drivers": ["host"],
      "parameters": {
        "properties": {
          "imageTopic": {"type": "string", "default": "/usb_cam/image_raw"},
          "cameraInfoTopic": {"type": "string", "default": "/usb_cam/camera_info"},
          "outputFile": {"type": "string", "default": "/var/lib/xgc2/camera/calibrations/usb_cam/intrinsics.yaml"},
          "referencesDir": {"type": "string", "default": "/var/lib/xgc2/camera/calibrations/usb_cam/intrinsic_refs"},
          "boardCols": {"type": "integer", "default": 7, "minimum": 2, "maximum": 100},
          "boardRows": {"type": "integer", "default": 5, "minimum": 2, "maximum": 100},
          "squareSize": {"type": "number", "default": 0.2, "minimum": 0.000001},
          "boardX": {"type": "number", "default": 2.0},
          "boardY": {"type": "number", "default": 0.0},
          "boardZ": {"type": "number", "default": 1.5},
          "displayWidth": {"type": "integer", "default": 720, "minimum": 64, "maximum": 16384},
          "intrinsicRate": {"type": "number", "default": 6.0, "minimum": 0.1, "maximum": 120.0},
          "jpegQuality": {"type": "integer", "default": 80, "minimum": 1, "maximum": 100},
          "cameraControl": {"type": "boolean", "default": false},
          "cameraModelName": {"type": "string", "default": "gazebo_static_camera"},
          "cameraControlTimeout": {"type": "number", "default": 8.0, "minimum": 0.0},
          "bindAddress": {"type": "string", "default": "127.0.0.1"},
          "httpPort": {"type": "integer", "default": 8766, "minimum": 1, "maximum": 65535},
          "frameAncestors": {"type": "string", "default": "'self' http://127.0.0.1:* http://localhost:*"},
          "allowedOrigins": {"type": "string", "default": ""},
          "rosMasterUri": {"type": "string", "default": "http://127.0.0.1:11311"},
          "rosLogDir": {"type": "string", "default": "/var/lib/xgc2/ros/log/camera-calibration"}
        },
        "additionalProperties": false
      },
      "command": {
        "executable": "/opt/ros/noetic/lib/xgc_camera_calibration/intrinsic_calibrator_web.py",
        "args": ["__name:=xgc_camera_intrinsic_calibrator_web", "_image_topic:=${imageTopic}", "_camera_info_topic:=${cameraInfoTopic}", "_output_file:=${outputFile}", "_references_dir:=${referencesDir}", "_board_cols:=${boardCols}", "_board_rows:=${boardRows}", "_square_size:=${squareSize}", "_board_x:=${boardX}", "_board_y:=${boardY}", "_board_z:=${boardZ}", "_display_width:=${displayWidth}", "_intrinsic_rate:=${intrinsicRate}", "_jpeg_quality:=${jpegQuality}", "_camera_control:=${cameraControl}", "_camera_model_name:=${cameraModelName}", "_camera_control_timeout:=${cameraControlTimeout}", "_bind_address:=${bindAddress}", "_http_port:=${httpPort}", "_frame_ancestors:=${frameAncestors}", "_allowed_origins:=${allowedOrigins}"],
        "env": {
          "ROS_MASTER_URI": "${rosMasterUri}",
          "ROS_LOG_DIR": "${rosLogDir}",
          "ROS_DISTRO": "noetic",
          "ROS_VERSION": "1",
          "ROS_PYTHON_VERSION": "3",
          "ROS_ROOT": "/opt/ros/noetic/share/ros",
          "ROS_PACKAGE_PATH": "/opt/ros/noetic/share",
          "PYTHONPATH": "/opt/ros/noetic/lib/python3/dist-packages",
          "PATH": "/opt/ros/noetic/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
